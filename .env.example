# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase — get from https://supabase.com/dashboard/project/<project>/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google Maps — get from https://console.cloud.google.com
# Required APIs: Maps JavaScript API, Places API, Distance Matrix API
# Restrict key to HTTP referrers: https://i78truckcenter.com/*, https://*.pages.dev/*, http://localhost:5173/*
VITE_GOOGLE_MAPS_API_KEY=AIza...
